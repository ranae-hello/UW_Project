# OBJECT ORIENTED PROGRAMMING (OOP)

# Classes (basically a blueprint)
class Car:

    # Attributes (data stored in an object)
    # __ means you can't change it
    __wheels = 4

class Car:

    # Functions can change the speed!
    def __innit__(self):
        self.__speed = 0

    # This can change the speed
    def drive(self, amount):
        self.__speed += amount
    
    # So can this
    def stop(self):
        self.__speed = 0
print(Car)

# Encapsulation - only allowing safe, controlled access. (Stops cyber hacking)

class Car:
    def __innit__(self, brand):
        self.brand = brand
        self.__speed = 0 # Private attribute

    def drive(self, amount):
        self.__speed += amount
    
    def stop(self):
        self.__speed = 0

# Inheritance (Giving a class to another)

# First class
class Car:
    def __innit__(self, brand, color):
        self.brand = brand
        self.color = color
        self.__speed = 0
    def drive(self, amount):
        self.__speed += amount

# Inherting Car and adding more.
class SportsCar(Car):
    def __innit__(self, brand, color, turbo):
        super().__innit__(brand, color)

        self.turbo = turbo
    def drive_with_turbo(self):
        self.__speed += self.turbo

# Changing some things inside sports car
my_sports_car = SportsCar("Ferrari", "Red", 50)
my_sports_car.drive(20)
my_sports_car.drive_with_turbo()