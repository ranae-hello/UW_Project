import pygame
import sys

pygame.init()

# Set window size
screen_width = 640
screen_height = 480

running = True
# Create display window
screen = pygame.display.set_mode((screen_width, screen_height))
clock = pygame.time.Clock()



pygame.display.set_caption("My First Pygame Window")
# 4. The Infinite Game Loop
while running:
    # Look at all user/system interactions
    for event in pygame.event.get():
        # If the user clicks the window's "X" button
        if event.type == pygame.QUIT:
            running = False

    # Fill screen background (optional color)
    screen.fill((255, 255, 255))
    pygame.draw.circle(screen, (0,0,255), (320, 240), 50)
    # Update the visual display window
    pygame.display.flip()

# 5. Clean exit cleanup 
pygame.quit()
sys.exit()