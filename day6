# TUPLES!!!
subject_tuple = ("math", "science", "english", "history")
print(subject_tuple)
print("")

# Accessing tuples
animals_tuple = ("cat", "dog", "rabbit", "hamster")
print(animals_tuple[1]) # Does the same thing list does but with a tuple

# Tuple conversion to list
animals_list2 = list(animals_tuple)
print(animals_list2)
animals_list2.insert(2, "orca")
animals_tuple2 = tuple(animals_list2)
print(animals_tuple2)
print("")

# Printing min and max (first and last)
print(min(animals_tuple2))
print(max(animals_tuple2))
print("")

