import statistics as sts

# Lists - use BRACKETS and all types can be stored in the same list (booleans, strings, integers, floats)
animals = ["turtles", "orcas", "bunnies", "10"]
print(animals)

# Append to insert at the end, insert to insert in the middle
animals.append("rabbit")
animals.insert(1, "kitty")
print(animals)

# Remove to remove and pop to remove and put in a different variable
animals.remove("rabbit")
print(animals)
forgotten_animal = animals.pop(2)
print(forgotten_animal)
print("")

