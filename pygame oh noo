    pygame.draw.rect(screen, (0,100,0), (x, y, 50, 100))
    pygame.draw.rect(screen, (0,100,0), (x + 70, y, 50, 200))
    pygame.draw.rect(screen, (0,100,0), (x - 70, y, 50, 150))




# User input
print("Welcome to the Dino Dynasty!")
name = input("PLEASE ENTER YOUR NAME: ")
print(f"Hello {name}! You are in Laramidia 66 million years in the past!")
print("You are trying to survive 4 meteors hitting Earth, each with it's respective difficulty.")
print("Collect money from dying and use it to get more gear, allowing you to survive each meteor.")
print("Get all levels and items ")
print("Goodluck! You'll need it :) \n")
player_stats["Name: "] = name
print(player_stats)
input("PRESS ENTER TO CONTINUE: ")
print("EASY : METEOR 1")
# Starting game loop
while True:

    # Make sure pygame doesn't crash
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit()
        keys = pygame.key.get_pressed()

    # Player movement
    if keys[pygame.K_UP] or keys[pygame.K_w]:
         y -= speed

    if keys[pygame.K_LEFT] or keys[pygame.K_a]:
         x -= speed

    if keys[pygame.K_DOWN] or keys[pygame.K_s]:
         y += speed

    if keys[pygame.K_RIGHT] or keys[pygame.K_d]:
         x += speed


            
    # Barriers to stop players from going out of bounds
    if x < 0:
         x = 0
    if x > 800:
         x = 800
    if y < 150:
         y = 150
    if y > 600:
         y = 600
    screen.fill((10,20,150))

    # Meteor
    if meteor_lvl == 1:
        print("")
        Meteor.drawing((135, 74, 74), 10)
        color = (135, 74, 74)
        size = 10


    # Dinosaur
    pygame.draw.rect(screen, (0,50,0), (0, 300, 10000, 1000000))
    pygame.draw.rect(screen, (0,100,0), (x - 180, y, 80, 45))
    pygame.draw.rect(screen, (0,100,0), (x, y, 50, 100))

    # LEGS!!
    pygame.draw.rect(screen, (0,100,0), (x + 70, y, 50, 200))
    pygame.draw.rect(screen, (0,100,0), (x - 70, y, 50, 200))

    # Walking animation!!
    if keys[pygame.K_UP] or keys[pygame.K_w] or keys[pygame.K_RIGHT] or keys[pygame.K_d]:
        legs()
    if keys[pygame.K_DOWN] or keys[pygame.K_s] or keys[pygame.K_LEFT] or keys[pygame.K_a]:
        legs2()

    # More dino
    pygame.draw.rect(screen, (0,100,0), (x + 140, y - 3, 50, 80))
    pygame.draw.rect(screen, (0,100,0), (x + 210, y - 70, 100, 80))
    pygame.draw.rect(screen, (0,100,0), (x + 210, y - 50, 170, 80))
    pygame.draw.rect(screen, (0,0,0), (x + 220, y - 60, 20, 20))
    pygame.draw.rect(screen, (0,0,0), (x + 280, y - 60, 20, 20))


    # Meteor getting bigger
    big += 1
    pygame.display.flip()

    clock.tick(60)
    if big > 500:
         print("You died!")    
         break