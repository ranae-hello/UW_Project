
# Importing libraries
import pygame
import sys
pygame.init()

# Starting variables
screen_width = 640
screen_height = 480
speed = 5
x = 220
y = 150
big = 1
name = ""
player_level = 1
player_health = 100
color = 1
size = 1
meteor_lvl = 1
clock = pygame.time.Clock()

# Screen for pygame
screen = pygame.display.set_mode((800, 600))

# Class for meteor
class Meteor:
    def drawing(color, size):
         # Drawing the meteor!!
        pygame.draw.line(screen, (0,0,0), (780,10), (700,70), 10)
        pygame.draw.line(screen, (0,0,0), (800,15), (720,80), 10)
        pygame.draw.line(screen, (0,0,0), (820,20), (740,90), 10)
        pygame.draw.circle(screen, (color), (700,100), size + big)
    # Some variables for the meteor
    def __innit__(self, health, name, lvl):

        self.name = name
        self.health = health
        self.lvl = lvl

    # Turning it into a string
    def __str__(self, health, name, lvl): 
         return f"Meteor name : {self.name} | Meteor health : {self.health} | Meteor level : {self.lvl}"
    
# Dictionary for player
player_stats = {"Name: " : name,
                "Level: " : player_level,
                "Health: " : player_health}



# Function for leg animation
def legs():
    screen.fill((10,20,150))
    pygame.draw.line(screen, (0,0,0), (780,10), (700,70), 10)
    pygame.draw.line(screen, (0,0,0), (800,15), (720,80), 10)
    pygame.draw.line(screen, (0,0,0), (820,20), (740,90), 10)
    pygame.draw.circle(screen, (color), (700,100), size + big)

    pygame.draw.rect(screen, (0,50,0), (0, 300, 10000, 1000000))
    pygame.draw.rect(screen, (0,100,0), (x - 180, y, 80, 45))
    pygame.draw.rect(screen, (0,100,0), (x, y, 50, 100))
    pygame.draw.rect(screen, (0,100,0), (x + 70, y, 50, 150))
    pygame.draw.rect(screen, (0,100,0), (x - 70, y, 50, 200))
def legs2():
    screen.fill((10,20,150))
    pygame.draw.line(screen, (0,0,0), (780,10), (700,70), 10)
    pygame.draw.line(screen, (0,0,0), (800,15), (720,80), 10)
    pygame.draw.line(screen, (0,0,0), (820,20), (740,90), 10)
    pygame.draw.circle(screen, (color), (700,100), size + big)

    
    pygame.draw.rect(screen, (0,50,0), (0, 300, 10000, 1000000))
